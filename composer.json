{
    "name": "scanlyser/php-sdk",
    "description": "PHP SDK for the ScanLyser API — accessibility, SEO, and security scanning.",
    "type": "library",
    "license": "MIT",
    "keywords": ["scanlyser", "accessibility", "wcag", "seo", "api", "sdk"],
    "homepage": "https://scanlyser.app",
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "laravel/pint": "^1.0"
    },
    "suggest": {
        "illuminate/support": "Required for the Laravel service provider (^11.0|^12.0|^13.0)"
    },
    "autoload": {
        "psr-4": {
            "ScanLyser\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ScanLyser\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ScanLyser\\Laravel\\ScanLyserServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
